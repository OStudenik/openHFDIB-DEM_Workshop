FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      HFDIBDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
bodyNames ("impeller_scaled");
// bodyNames ("sphereBody");

interpolationSchemes
{
  U cell;
}

surfaceThreshold    1e-4;
stepDEM     1;
geometricD (1 1 1);
recordSimulation true;
recordFirstTimeStep false;
nSolidsInDomain -1;       //Sets Upper Limit On Number Of Particles In Domain if not spcecified sets to 1000 by default


outputSetup
{
    basic true;
    iB  false;
    DEM false;
    addModel false;
    parallelDEM false;
}

impeller_scaled
{
    prescribedTransRotBody
    {
        velocity (0 0 0);
        omega 6.28;
        axis (0 0 1);
    }


    rho         rho [1 -3 0 0 0 0 0] 1;
    material particle;
    
    bodyGeom nonConvex;
    updateTorque false;
    sdBasedLambda false;
    interfaceSpan 1.0;
    startSynced false;
    refineBuffers -1;
    timesToSetStatic -1; //number of timeSteps in contact with wall/static body to set body as static. Never when -1
    bodyAddition
    {
        addModel once;
        onceCoeffs{}
    }
    material particle;
}

sphereBody
{
    prescribedTransRotBody
    {
        velocity (-0.5 -0.5 0);
        omega 0;
        axis (0 0 1);
    }


    rho         rho [1 -3 0 0 0 0 0] 1;
    material particle;
    
    bodyGeom sphere;
    sphere
    {
        radius 0.005;
        startPosition (0.02 0.02 0.0);
    }

    updateTorque false;
    sdBasedLambda false;
    interfaceSpan 1.0;
    startSynced false;
    refineBuffers -1;
    timesToSetStatic -1; //number of timeSteps in contact with wall/static body to set body as static. Never when -1
    bodyAddition
    {
        addModel once;
        onceCoeffs{}
    }
    material particle;
}

// -- required for repeatRandomPosition addModel ---------------(START)-
DEM
{
    // LcCoeff 4.0;
    // LcCoeff 0.55;
    // rotationModel chen2012;
	// rotationModel mindlin1953
    materials
    {
        particle
        {
            Y       1;
            nu      0;
            mu      0;
            adhN    0;
            eps     1;
        }

        wall
        {
            Y       1;
            nu      0;
            mu      0;
            adhN    0;
            eps     1;
        }
    }

    collisionPatches
    {

    }
}

virtualMesh
{
    level 2;
    charCellSize 0.001;
}
// -- required for repeatRandomPosition addModel -----------------(END)-
