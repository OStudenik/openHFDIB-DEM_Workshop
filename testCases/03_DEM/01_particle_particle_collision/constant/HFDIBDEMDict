FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      HFDIBDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
bodyNames ("sphereTop" "sphereBottom");

interpolationSchemes
{
  U cell;
}

surfaceThreshold    1e-4;

stepDEM     1;
// stepDEM     0.1;
// stepDEM     0.01;

geometricD (1 1 1);
recordSimulation true;
recordFirstTimeStep false;
nSolidsInDomain -1;       //Sets Upper Limit On Number Of Particles In Domain if not spcecified sets to 1000 by default


outputSetup
{
    basic true;
    iB  false;
    DEM false;
    addModel false;
    parallelDEM false;
}

DEM
{
    // LcCoeff 4.0;
    LcCoeff 0.55;
    // rotationModel chen2012;
	rotationModel mindlin1953;
    materials
    {
        particle
        {
            Y       5e7; 
            nu      0;
            mu      0;
            adhN    0;
            eps     1;
            // eps     0.95;
            // eps     0.8;
            // eps     0.05;
        }
    }

    collisionPatches
    {

    }
}


sphereTop
{

    fullyCoupledBody
    {
        velocity (0.0 -1 0.0);
    }

    rho         rho [1 -3 0 0 0 0 0] 2500;
    material particle;
    
    bodyGeom sphere;
    sphere
    {
        radius 0.005;
        startPosition (0.0 0.015 0.0);
    }
    updateTorque false;
    
    sdBasedLambda false;
    interfaceSpan 1.0;
    startSynced false;
    refineBuffers -1;
    timesToSetStatic -1; //number of timeSteps in contact with wall/static body to set body as static. Never when -1

    bodyAddition
    {
        addModel once;
        onceCoeffs{}
    }
    material particle;
}

sphereBottom
{

    fullyCoupledBody
    {
        velocity (0.0 1 0.0);
    }

    rho         rho [1 -3 0 0 0 0 0] 2500;
    material particle;
    
    bodyGeom sphere;
    sphere
    {
        radius 0.005;
        startPosition (0.0 -0.015 0.0);
    }

    updateTorque false;

    sdBasedLambda false;
    interfaceSpan 1.0;
    startSynced false;
    refineBuffers -1;
    timesToSetStatic -1; //number of timeSteps in contact with wall/static body to set body as static. Never when -1
    bodyAddition
    {
        addModel once;
        onceCoeffs{}
    }
    material particle;
}

