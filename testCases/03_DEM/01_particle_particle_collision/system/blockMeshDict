FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale 0.01;

cubeXMin -1;
cubeXMax 1;

cubeYMin -3;
cubeYMax 3;

cubeZMin -1;
cubeZMax 1;

Xresolution 20;
Yresolution 60;
Zresolution 20;

vertices
(
  ($cubeXMin       $cubeYMin      $cubeZMin)
  ($cubeXMax       $cubeYMin      $cubeZMin)
  ($cubeXMax       $cubeYMax      $cubeZMin)
  ($cubeXMin       $cubeYMax      $cubeZMin)
  ($cubeXMin       $cubeYMin      $cubeZMax)
  ($cubeXMax       $cubeYMin      $cubeZMax)
  ($cubeXMax       $cubeYMax      $cubeZMax)
  ($cubeXMin       $cubeYMax      $cubeZMax)
);

blocks
(
  hex (0 1 2 3 4 5 6 7) ($Xresolution $Yresolution $Zresolution) simpleGrading (1 1 1)
);

edges
(
);

boundary
(
  z1
{
  type wall;
  faces
  (
   (4 5 6 7)
  );
}

z0
{
  type wall;
  faces
  (
   (0 3 2 1)
  );
}

x1
{
type wall;
  faces
  (
  (2 6 5 1)
 );
}

x0
{
type wall;
  faces
  (
  (0 4 7 3)
  );
}

y0
{
  type wall;
  faces
  (
  (0 1 5 4)
  );
}
y1
{
  type patch;
  faces
  (
  (3 7 6 2)
  );
}
);

mergePatchPairs
(
);

